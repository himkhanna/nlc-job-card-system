# Frontend (Vite — prefix with VITE_)
VITE_API_BASE_URL=http://localhost:5000

# Backend (ASP.NET Core)
ConnectionStrings__DefaultConnection=Host=localhost;Port=5432;Database=nlc_jobcard;Username=postgres;Password=yourpassword
ConnectionStrings__Redis=localhost:6379
Jwt__Secret=your-super-secret-key-minimum-32-characters
Jwt__Issuer=nlc-api
Jwt__Audience=nlc-frontend
Jwt__ExpiryMinutes=60
Jwt__RefreshExpiryDays=7
AllowedOrigin=http://localhost:3000
